<% layout("/layouts/boilerplate.ejs") -%>
<body>

<style>
    .listing-card {
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 10px rgba(0,0,0,.1);
    }

    .listing-card img {
        width: 100%;
        height: 420px;
        object-fit: cover;
    }

    .action-buttons{
        display:flex;
        gap:10px;
        margin:20px 0;
        flex-wrap:wrap;
    }

    .review-card{
        box-shadow:0 2px 8px rgba(0,0,0,.08);
        border-radius:10px;
    }

    @media(max-width:991px){

        .listing-card img{
            height:320px;
        }

    }

    @media(max-width:768px){

        .listing-card img{
            height:250px;
        }

        .action-buttons{
            flex-direction:column;
        }

        .action-buttons form{
            width:100%;
        }

        .action-buttons .btn{
            width:100%;
        }

        textarea{
            width:100%;
        }

        h3{
            font-size:1.5rem;
        }

        .starability-checkmark{
            transform:scale(.9);
            transform-origin:left;
        }
    }

    @media(max-width:576px){

        .listing-card img{
            height:220px;
        }

        h3{
            font-size:1.3rem;
        }

        .card-body{
            padding:1rem;
        }

        .starability-checkmark{
            transform:scale(.8);
        }
    }
</style>

<div class="container my-4">

    <div class="row justify-content-center">

        <div class="col-12 col-lg-9">

            <h3 class="mb-3"><b><%= listing.title %></b></h3>

            <div class="row">

                <div class="col-12 col-md-10 col-lg-8">

                    <div class="card listing-card">

                        <img src="<%= listing.image.url %>" class="card-img-top" alt="Listing Image">

                        <div class="card-body">

                            <p><strong>Owned by:</strong> <%= listing.owner.username %></p>

                            <p><%= listing.description %></p>

                            <p><strong>Price:</strong> &#8377;<%= listing.price.toLocaleString("en-IN") %></p>

                            <p><strong>Location:</strong> <%= listing.location %></p>

                            <p><strong>Country:</strong> <%= listing.country %></p>

                        </div>

                    </div>

                </div>

            </div>

            <% if(currUser && listing.owner.equals(currUser._id)){ %>

            <div class="action-buttons">

                <form method="get" action="/listing/<%= listing._id %>/edit">

                    <button class="btn btn-dark">Edit</button>

                </form>

                <form method="post" action="/listing/<%= listing._id %>?_method=DELETE">

                    <button class="btn btn-danger">Delete</button>

                </form>

            </div>

            <% } %>

            <% if(currUser){ %>

            <hr>

            <form method="POST"
                  action="/listing/<%= listing._id %>/review"
                  novalidate
                  class="needs-validation">

                <h3 class="mb-3">Leave a Review</h3>

                <div class="mb-3">

                    <label class="form-label">Rating</label>

                    <fieldset class="starability-checkmark">

                        <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating."/>

                        <input type="radio" id="first-rate1" name="review[rating]" value="1"/>
                        <label for="first-rate1">1 star</label>

                        <input type="radio" id="first-rate2" name="review[rating]" value="2"/>
                        <label for="first-rate2">2 stars</label>

                        <input type="radio" id="first-rate3" name="review[rating]" value="3"/>
                        <label for="first-rate3">3 stars</label>

                        <input type="radio" id="first-rate4" name="review[rating]" value="4"/>
                        <label for="first-rate4">4 stars</label>

                        <input type="radio" id="first-rate5" name="review[rating]" value="5"/>
                        <label for="first-rate5">5 stars</label>

                    </fieldset>

                </div>

                <div class="mb-3">

                    <label for="comment" class="form-label">Comments</label>

                    <textarea
                        rows="5"
                        name="review[comment]"
                        id="comment"
                        class="form-control"
                        required></textarea>

                    <div class="valid-feedback">
                        Looks good!
                    </div>

                    <div class="invalid-feedback">
                        Please enter a comment.
                    </div>

                </div>

                <button type="submit" class="btn btn-outline-dark">
                    Submit
                </button>

            </form>

            <% } %>

            <hr>

            <div class="row g-3">

                <% for(let review of listing.reviews){ %>

                <div class="col-12 col-md-6">

                    <div class="card review-card h-100">

                        <div class="card-body">

                            <h5>@<%= review.author.username %></h5>

                            <p class="starability-result" data-rating="<%= review.rating %>"></p>

                            <p><%= review.comment %></p>

                            <form method="post"
                                  action="/listing/<%= listing._id %>/review/<%= review._id %>?_method=DELETE">

                                <button class="btn btn-dark btn-sm">
                                    Delete
                                </button>

                            </form>

                        </div>

                    </div>

                </div>

                <% } %>

            </div>

        </div>

    </div>

</div>

</body>