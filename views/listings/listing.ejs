<% layout("/layouts/boilerplate.ejs") -%>
<body>

<style>

    /* ---------------- Filters ---------------- */

    #filters{
        display:flex;
        flex-wrap:wrap;
        justify-content:center;
        align-items:center;
        gap:1.5rem;
        margin:2rem 0;
    }

    .filter{
        text-align:center;
        opacity:.7;
        transition:.3s;
        cursor:pointer;
        min-width:80px;
    }

    .filter:hover{
        opacity:1;
        transform:translateY(-3px);
    }

    .filter i{
        font-size:1.4rem;
    }

    .filter p{
        margin-top:.5rem;
        font-size:.85rem;
        margin-bottom:0;
    }

    /* ---------------- Listings ---------------- */

    .listing-link{
        text-decoration:none;
        color:#222;
    }

    .listing-card{
        border:none;
        background:transparent;
        box-shadow:none;
        transition:.3s;
    }

    .listing-card:hover{
        transform:translateY(-6px);
    }

    .listing-card img{
        width:100%;
        height:300px;
        object-fit:cover;
        border-radius:18px;
    }

    .card-body{
        background:transparent;
        padding:10px 2px;
    }

    .card-text{
        font-size:1rem;
        margin-bottom:0;
        color:#222;
    }

    /* ---------------- Tablet ---------------- */

    @media(max-width:992px){

        .listing-card img{
            height:260px;
        }

    }

    /* ---------------- Mobile ---------------- */

    @media(max-width:768px){

        #filters{
            gap:1rem;
        }

        .filter i{
            font-size:1.2rem;
        }

        .filter p{
            font-size:.75rem;
        }

        .listing-card img{
            height:240px;
        }

    }

    @media(max-width:576px){

        #filters{
            flex-wrap:nowrap;
            overflow-x:auto;
            justify-content:flex-start;
            padding-bottom:10px;
        }

        #filters::-webkit-scrollbar{
            display:none;
        }

        .filter{
            flex:0 0 auto;
        }

        .listing-card img{
            height:220px;
        }

    }

</style>

<div class="container">

    <!-- Filters -->

    <div id="filters">

        <div class="filter">
            <i class="fa-solid fa-fire"></i>
            <p>Trending</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-mountain-city"></i>
            <p>Iconic Cities</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-mountain"></i>
            <p>Mountains</p>
        </div>

        <div class="filter">
            <i class="fa-brands fa-fort-awesome"></i>
            <p>Castles</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-person-swimming"></i>
            <p>Amazing Pools</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-person-hiking"></i>
            <p>Camping</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-cow"></i>
            <p>Farms</p>
        </div>

        <div class="filter">
            <i class="fa-solid fa-snowflake"></i>
            <p>Arctic</p>
        </div>

    </div>

    <!-- Listings -->

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-5">

        <% for(let listing of allListings){ %>

        <div class="col">

            <a href="/listing/<%= listing._id %>" class="listing-link">

                <div class="card listing-card">

                    <img
                        src="<%= listing.image.url %>"
                        class="card-img-top"
                        alt="listing image"
                    >

                    <div class="card-body">

                        <p class="card-text">
                            <strong><%= listing.title %></strong>
                        </p>

                        <p class="card-text">
                            &#8377;<%= listing.price.toLocaleString("en-IN") %>/night
                        </p>

                    </div>

                </div>

            </a>

        </div>

        <% } %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>