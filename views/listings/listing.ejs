<% layout("/layouts/boilerplate.ejs") -%>
<body>

<style>

    /* Filters */

    #filters{
        display:flex;
        flex-wrap:wrap;
        justify-content:center;
        align-items:center;
        gap:1.5rem;
        margin:2rem 0;
    }

    .filter{
        text-align:center;
        opacity:.7;
        cursor:pointer;
        transition:.3s;
        min-width:80px;
    }

    .filter:hover{
        opacity:1;
        transform:translateY(-4px);
    }

    .filter i{
        font-size:1.4rem;
    }

    .filter p{
        font-size:.85rem;
        margin-top:.5rem;
        margin-bottom:0;
    }

    /* Cards */

    .listing-link{
        text-decoration:none;
        color:black;
        display:block;
        width:100%;
    }

    .listing-card{
        border:none;
        border-radius:15px;
        overflow:hidden;
        width:90%;
        margin:0 auto;
        box-shadow:0 4px 12px rgba(0,0,0,.1);
        transition:.3s;
    }

    .listing-card:hover{
        transform:translateY(-6px);
        box-shadow:0 12px 25px rgba(0,0,0,.18);
    }

    .listing-card img{
        width:100%;
        height:300px;
        object-fit:cover;
    }

    .card-body{
        padding:1rem;
    }

    .card-text{
        color:#222;
        font-size:1rem;
        margin-bottom:0;
    }

    /* Tablet */

    @media(max-width:992px){

        .listing-card{
            width:95%;
        }

        .listing-card img{
            height:270px;
        }

    }

    /* Mobile */

    @media(max-width:768px){

        #filters{
            gap:1rem;
        }

        .filter i{
            font-size:1.2rem;
        }

        .filter p{
            font-size:.75rem;
        }

        .listing-card{
            width:100%;
        }

        .listing-card img{
            height:240px;
        }

    }

    @media(max-width:576px){

        #filters{
            flex-wrap:nowrap;
            overflow-x:auto;
            justify-content:flex-start;
            padding-bottom:10px;
        }

        #filters::-webkit-scrollbar{
            display:none;
        }

        .filter{
            flex:0 0 auto;
        }

        .listing-card img{
            height:220px;
        }

    }

</style>

<div class="container">

    <!-- Filters -->

    <div id="filters">

        <div class="filter">
            <div><i class="fa-solid fa-fire"></i></div>
            <p>Trending</p>
        </div>

        <div class="filter">
            <div><i class="fa-solid fa-mountain-city"></i></div>
            <p>Iconic Cities</p>
        </div>

        <div class="filter">
            <div><i class="fa-solid fa-mountain"></i></div>
            <p>Mountains</p>
        </div>

        <div class="filter">
            <div><i class="fa-brands fa-fort-awesome"></i></div>
            <p>Castles</p>
        </div>

        <div class="filter">
            <div><i class="fa-solid fa-person-swimming"></i></div>
            <p>Amazing Pools</p>
        </div>

        <div class="filter">
            <div><i class="fa-solid fa-person-hiking"></i></div>
            <p>Camping</p>
        </div>

        <div class="filter">
            <div><i class="fa-solid fa-cow"></i></div>
            <p>Farms</p>
        </div>

        <div class="filter">
            <div><i class="fa-solid fa-snowflake"></i></div>
            <p>Arctic</p>
        </div>

    </div>

    <!-- Listings -->

    <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-3 gx-5 gy-5 justify-content-center">

        <% for(let listing of allListings){ %>

        <div class="col d-flex justify-content-center">

            <a href="/listing/<%= listing._id %>" class="listing-link">

                <div class="card listing-card">

                    <img src="<%= listing.image.url %>" class="card-img-top" alt="alternative_image">

                    <div class="card-img-overlay"></div>

                    <div class="card-body">

                        <p class="card-text">

                            <strong><%= listing.title %></strong>

                            <br>

                            &#8377;<%= listing.price.toLocaleString("en-IN") %>/night

                        </p>

                    </div>

                </div>

            </a>

        </div>

        <% } %>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
crossorigin="anonymous"></script>

</body>